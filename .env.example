# Server
PORT=3001

# MongoDB Atlas
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CLUSTER=atlascluster.iw56sdc.mongodb.net

# JWT
SECRET_KEY=your_jwt_secret

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=your_sender_email

# Razorpay (use rzp_test_ keys for testing, rzp_live_ for production)
PUBLIC_KEY=rzp_test_your_key_id
PRIVATE_KEY=your_razorpay_key_secret
WEBHOOK_SECRET=your_webhook_secret

# CORS (set to your Netlify URL after frontend deploy)
ALLOWED_ORIGIN=https://your-app.netlify.app
